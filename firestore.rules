rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Matches the users collection
    match /users/{userId} {
      // Anyone can read a user profile (needed for public profiles/gig posters)
      allow read: if true;
      
      // A user can only create or update their own profile document
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Deleting profiles is blocked from the client SDKs
      allow delete: if false;
    }

    // Matches the gigs collection
    match /gigs/{gigId} {
      // Anyone can read gigs (for the home feed)
      allow read: if true;
      
      // Any authenticated user can create a gig (poster).
      // They MUST set themselves as the client_id.
      allow create: if isAuthenticated() 
                    && request.resource.data.client_id == request.auth.uid;
                    
      // Only the client (poster) can update a gig (e.g., closing it).
      allow update: if isAuthenticated() 
                    && resource.data.client_id == request.auth.uid
                    && request.resource.data.client_id == request.auth.uid; // Cannot change owner
      
      allow delete: if false; // Soft deletes via status='deleted' preferrable
    }
    
    // Matches gig applications
    match /gig_applications/{applicationId} {
       // Workers can read their own applications. Posters can read applications for their gigs.
       allow read: if isAuthenticated() && (
         resource.data.worker_id == request.auth.uid ||
         get(/databases/$(database)/documents/gigs/$(resource.data.gig_id)).data.client_id == request.auth.uid
       );
       
       // Workers can apply to a gig. They must set themselves as the worker.
       allow create: if isAuthenticated() && request.resource.data.worker_id == request.auth.uid;
       
       // Only the poster of the gig can update the application status (e.g. accepting/rejecting)
       allow update: if isAuthenticated() && 
         get(/databases/$(database)/documents/gigs/$(resource.data.gig_id)).data.client_id == request.auth.uid;
         
       allow delete: if false;
    }

    // ─── Chat Threads ───────────────────────────────────────────────
    match /chats/{chatId} {
      // Helper: is the requesting user a participant in this chat?
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      function isParticipantNew() {
        return request.auth.uid in request.resource.data.participantIds;
      }

      // Only participants can read a chat thread
      allow read: if isAuthenticated() && isParticipant();

      // Any authenticated user can create a chat, but they must be a participant
      allow create: if isAuthenticated() && isParticipantNew();

      // Only participants can update (e.g. lastMessage, unreadCounts)
      allow update: if isAuthenticated() && isParticipant();

      // No client-side deletes
      allow delete: if false;

      // ─── Chat Messages (subcollection) ──────────────────────────
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if isAuthenticated()
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;

        // Only chat participants can send messages, and must be the sender
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
                      && request.resource.data.senderId == request.auth.uid;

        // Messages are immutable once sent
        allow update, delete: if false;
      }
    }

  }
}
